{
  "name": "tree-sitter-arvia",
  "version": "0.4.1",
  "private": true,
  "description": "Tree-sitter grammar for the Arvia design-system language (.arv).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arviahq/arvia.git",
    "directory": "packages/tree-sitter-arvia"
  },
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "queries/*",
    "src/**"
  ],
  "main": "bindings/node",
  "types": "bindings/node",
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter generate && tree-sitter test",
    "install": "node-gyp-build",
    "prebuildify": "prebuildify --napi --strip"
  },
  "dependencies": {
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "prebuildify": "^6.0.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "tree_sitter": {
      "optional": true
    }
  },
  "tree-sitter": [
    {
      "scope": "source.arv",
      "file-types": [
        "arv"
      ],
      "injection-regex": "^arvia?$",
      "highlights": "queries/highlights.scm"
    }
  ]
}
