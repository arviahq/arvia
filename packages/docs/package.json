{
  "name": "@arviahq/docs",
  "version": "0.5.1",
  "description": "Generate design token documentation from .arv theme files.",
  "homepage": "https://github.com/arviahq/arvia#readme",
  "bugs": {
    "url": "https://github.com/arviahq/arvia/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arviahq/arvia.git",
    "directory": "packages/docs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@arviahq/compiler": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "vitest": "^3.2.4"
  }
}
