{
  "name": "@arviahq/storybook",
  "version": "0.5.0",
  "description": "Generate Storybook CSF stories from .arv component metadata.",
  "homepage": "https://github.com/Fausto95/arvia#readme",
  "bugs": {
    "url": "https://github.com/Fausto95/arvia/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fausto95/arvia.git",
    "directory": "packages/storybook"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@arviahq/compiler": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "vitest": "^3.2.4"
  }
}
