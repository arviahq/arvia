{
  "name": "@arviahq/compiler",
  "version": "0.6.1",
  "description": "Compiler for .arv design-system files: CSS, JS and TypeScript declaration generation.",
  "homepage": "https://github.com/arviahq/arvia#readme",
  "bugs": {
    "url": "https://github.com/arviahq/arvia/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arviahq/arvia.git",
    "directory": "packages/compiler"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "css-tree": "^3.2.1"
  },
  "devDependencies": {
    "@types/css-tree": "^2.3.11"
  }
}
