theme {
  breakpoint {
    sm = 480px;
    md = 768px;
    lg = 1024px;
  }
  container-size {
    narrow = 320px;
    wide = 560px;
  }
}

component Panel {
  base {
    display: block;
    padding: 4px;

    @media (min-width: breakpoint.md) {
      padding: 8px;
    }
    @media (width < breakpoint.lg) {
      padding: 4px;
    }
    @media (breakpoint.sm <= width < breakpoint.lg) {
      padding: 8px;
    }
    @media (min-width: 900px) {
      padding: 12px;
    }

    @container (inline-size < container-size.wide) {
      flex-direction: column;
    }
    @container (container-size.narrow <= inline-size < container-size.wide) {
      flex-direction: row;
    }
  }
}
