{
  "name": "@arviahq/typescript-plugin",
  "version": "0.6.1",
  "description": "TypeScript plugin for .arv files: virtual types and arvia-tsc CLI — no generated .d.ts files needed.",
  "homepage": "https://github.com/arviahq/arvia#readme",
  "bugs": {
    "url": "https://github.com/arviahq/arvia/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arviahq/arvia.git",
    "directory": "packages/typescript-plugin"
  },
  "bin": {
    "arvia-tsc": "./bin/arvia-tsc.cjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "commonjs",
  "main": "./dist/tsserver.cjs",
  "types": "./dist/tsserver.d.cts",
  "exports": {
    ".": {
      "types": "./dist/tsserver.d.cts",
      "require": "./dist/tsserver.cjs"
    },
    "./plugin": {
      "types": "./dist/languagePlugin.d.cts",
      "require": "./dist/languagePlugin.cjs"
    },
    "./cli": {
      "require": "./dist/cli.cjs"
    },
    "./vue-cli": {
      "require": "./dist/vue-cli.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsdown --config-loader unrun",
    "dev": "tsdown --config-loader unrun --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@arviahq/compiler": "workspace:*",
    "@volar/language-core": "^2.4.15",
    "@volar/typescript": "^2.4.15"
  },
  "devDependencies": {
    "@vue/language-core": "^3.3.4",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@vue/language-core": "^3.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/language-core": {
      "optional": true
    }
  }
}
