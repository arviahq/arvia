keyframes pulse {
  from { opacity: 1; }
  to { opacity: 0.45; }
}

component RecipePulseBox {
  base {
    padding: space.4 space.5;
    border-radius: radius.md;
    background: color.primary;
    color: white;
    font-size: font.sm;
    animation: keyframes.pulse duration.normal easing.default infinite alternate;
  }
}
