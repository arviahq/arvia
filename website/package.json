{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @arviahq/vite-plugin-react... build",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "arvia-tsc --noEmit",
    "fbtee:collect": "fbtee collect --src src",
    "fbtee:translate": "fbtee translate --translations translations/*.json --output-dir src/translations",
    "i18n:sync": "pnpm fbtee:collect && pnpm fbtee:translate"
  },
  "dependencies": {
    "@arviahq/compiler": "workspace:*",
    "@arviahq/language-server": "workspace:^",
    "@docsearch/css": "^4.6.3",
    "@docsearch/react": "^4.6.3",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-router": "^1.170.15",
    "@vue/compiler-sfc": "3.5.38",
    "clsx": "^2.1.1",
    "fbtee": "^1.5.0",
    "minisearch": "^7.2.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shiki": "^3.4.0",
    "sucrase": "^3.35.1"
  },
  "devDependencies": {
    "@arviahq/vite-plugin-react": "workspace:*",
    "@nkzw/babel-preset-fbtee": "^1.5.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tsx": "^4.22.4",
    "vite": "^7.3.0"
  },
  "volta": {
    "node": "22.22.3"
  }
}
