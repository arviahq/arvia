component RecipeResponsiveButton {
  base {
    display: inline-flex;
    border: none;
    border-radius: radius.md;
    background: color.primary;
    color: white;
    font: inherit;
    cursor: pointer;

    // Small by default; bumps up at the md breakpoint.
    padding: space.1 space.3;
    font-size: font.sm;

    @media (min-width: breakpoint.md) {
      padding: space.3 space.5;
      font-size: font.lg;
    }
  }
}
