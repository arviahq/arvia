component RecipeContainerCard {
  base {
    container-type: inline-size;
    display: flex;
    padding: space.4;
    border-radius: radius.md;
    border: 1px solid color.border;
    background: color.surface;

    // Stacked by default; switches to a row past the wide container token.
    flex-direction: column;
    gap: space.2;

    @container (min-width: container-size.wide) {
      flex-direction: row;
      gap: space.4;
      align-items: center;
    }
  }
}
