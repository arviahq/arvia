{
  "name": "design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "pretypecheck": "arvia gen src",
    "typecheck": "tsc --noEmit",
    "predocs": "arvia gen --docs --theme src/theme.arv --out docs/tokens",
    "prestorybook": "arvia gen --storybook --out ../stories/generated --theme src/theme.arv --include atoms,language src",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@arviahq/vite-plugin-react": "workspace:*",
    "@storybook/react": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "storybook": "^9.0.0",
    "vite": "^7.3.0"
  }
}
