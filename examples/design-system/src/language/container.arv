component ContainerDemo {
  base {
    display: flex;
    padding: space.4;
    border-radius: radius.md;
    border: 1px solid color.border;
    background: color.surface;
  }

  variants {
    layout {
      stacked {
        flex-direction: column;
        gap: space.2;
      }
      row {
        flex-direction: row;
        gap: space.4;
        align-items: center;
      }
    }
  }

  defaults {
    layout: stacked;
  }

  container {
    wide { layout: row; }
  }
}
