component LocalTokensDemo {
  tokens {
    space {
      pad = 6px;
    }
    metrics {
      radius = 999px;
    }
  }

  base {
    display: inline-flex;
    padding: space.pad space.2;
    border-radius: metrics.radius;
    background: color.primary;
    color: white;
    font-size: font.sm;
  }
}
