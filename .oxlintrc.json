{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "plugins": ["typescript", "unicorn", "oxc"],
  "rules": {
    "no-unused-vars": "error",
    "unicorn/require-module-specifiers": "off"
  },
  "overrides": [
    {
      "files": ["**/tests/**"],
      "rules": {
        "unicorn/consistent-function-scoping": "off"
      }
    },
    {
      "files": ["packages/tree-sitter-arvia/grammar.js"],
      "rules": {
        "no-underscore-dangle": "off"
      }
    }
  ],
  "ignorePatterns": [
    "**/dist/**",
    "**/node_modules/**",
    "**/__snapshots__/**",
    "**/*.arv.d.ts",
    "packages/tree-sitter-arvia/bindings/**",
    "packages/tree-sitter-arvia/src/**"
  ]
}
